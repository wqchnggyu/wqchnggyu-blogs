---
// Waline comment system component
// https://waline.js.org
---

<section class="waline-wrapper mx-auto mt-8 w-full max-w-app" aria-label="评论区" data-pagefind-ignore>
  <div id="waline"></div>
</section>

<script is:inline>
  // ── Waline 评论系统：动态加载 + 主题同步 ─────────────────────────────

  // ── 动态加载 Waline ─────────────────────────────────────────────────
  function loadWaline() {
    const container = document.getElementById("waline");
    if (!container) return false;

    // 避免重复初始化
    if (container.dataset.walineInitialized === "true") return true;

    // 加载 Waline CSS
    if (!document.getElementById("waline-css")) {
      const link = document.createElement("link");
      link.id = "waline-css";
      link.rel = "stylesheet";
      link.href = "https://unpkg.com/@waline/client@v3/dist/waline.css";
      document.head.appendChild(link);
    }

    // 加载 Waline JS 并初始化
    import("https://unpkg.com/@waline/client@v3/dist/waline.js")
      .then(({ init }) => {
        init({
          el: "#waline",
          serverURL: "https://comment-waline.wqch.net/",
          lang: "zh-CN",
          login: "force",              // 强制登录后才能评论
          pageview: true,              // 开启访问量统计
          // 传入 CSS 选择器字符串，Waline 自动监听 <html data-theme="dark"> 变化
          // 主题切换时无需任何额外代码即可同步
          dark: 'html[data-theme="dark"]',
          path: window.location.pathname,
          turnstileKey: "0x4AAAAAACwyghHQumb0yAjk", // Cloudflare Turnstile 验证
        });

        container.dataset.walineInitialized = "true";
      })
      .catch(err => {
        console.error("Waline 加载失败:", err);
      });

    return true;
  }

  // ── 等待容器就绪（含重试）────────────────────────────────────────────
  function tryLoad(retries) {
    if (loadWaline()) return;
    if (retries > 0) {
      requestAnimationFrame(() => tryLoad(retries - 1));
    }
  }

  // ── 初始化 ───────────────────────────────────────────────────────────
  function initWaline() {
    // 重置初始化标志（用于 View Transitions）
    const container = document.getElementById("waline");
    if (container) {
      container.dataset.walineInitialized = "false";
    }
    tryLoad(5);
  }

  // 首次加载
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initWaline, { once: true });
  } else {
    initWaline();
  }

  // Astro View Transitions：页面切换后重新挂载
  document.addEventListener("astro:after-swap", () => {
    requestAnimationFrame(() => {
      initWaline();
    });
  });
</script>

<style is:global>
  /* ── Waline 自定义样式：强调色 #B0C4DE + 阴影 ─────────────────────── */

  /* 将所有强调色变量统一放在 .waline-wrapper 作用域内，
     优先级高于 Waline 自身在 :root 的默认值 */
  .waline-wrapper {
    /* 主题强调色 */
    --waline-theme-color: #B0C4DE;
    --waline-active-color: #9ab3d0;
    /* 徽章色（管理员/作者标签） */
    --waline-badge-color: #B0C4DE;
    /* 阴影 */
    --waline-box-shadow: 0 2px 8px rgba(176, 196, 222, 0.15);

    /* 跟随站点背景/文字/边框 */
    --waline-white: var(--background);
    --waline-bg-color: var(--background);
    --waline-bg-color-light: var(--muted);
    --waline-border-color: var(--border);
    --waline-color: var(--foreground);
  }

  /* 暗色模式：阴影加深，强调色保持不变 */
  [data-theme="dark"] .waline-wrapper {
    --waline-theme-color: #B0C4DE;
    --waline-active-color: #9ab3d0;
    --waline-badge-color: #B0C4DE;
    --waline-box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);

    --waline-white: var(--background);
    --waline-bg-color: var(--background);
    --waline-bg-color-light: var(--muted);
    --waline-border-color: var(--border);
    --waline-color: var(--foreground);
  }
</style>
