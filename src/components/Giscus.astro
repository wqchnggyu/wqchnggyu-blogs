---
// Giscus comment system component
// https://giscus.app
---

<section class="giscus-wrapper mx-auto mt-8 w-full max-w-app" aria-label="评论区" data-pagefind-ignore>
  <div class="giscus"></div>
</section>

<script is:inline>
  // ── Giscus 评论系统：动态注入 + 主题同步 + 重试保障 ─────────────────

  function getSiteTheme() {
    // 最可靠的数据源：<html data-theme="...">
    // Layout.astro 的内联防闪脚本最先执行，已将正确主题写入此属性
    const attr = document.documentElement.getAttribute("data-theme");
    if (attr === "dark" || attr === "light") return attr;
    // 兜底：localStorage → 系统偏好
    const stored = localStorage.getItem("theme");
    if (stored === "light" || stored === "dark") return stored;
    return window.matchMedia("(prefers-color-scheme: dark)").matches
      ? "dark"
      : "light";
  }

  // ── 1. 动态注入 giscus client.js ──────────────────────────────────────
  function injectGiscus() {
    const container = document.querySelector(".giscus");
    if (!container) return false;

    // 避免 View Transitions 重复注入
    if (container.querySelector("script[data-giscus-injected]")) return true;

    const theme = getSiteTheme();

    const script = document.createElement("script");
    script.src = "https://giscus.app/client.js";
    script.setAttribute("data-repo", "wqchnggyu/Comments");
    script.setAttribute("data-repo-id", "R_kgDORvYn3w");
    script.setAttribute("data-category", "General");
    script.setAttribute("data-category-id", "DIC_kwDORvYn384C5KdW");
    script.setAttribute("data-mapping", "pathname");
    script.setAttribute("data-strict", "0");
    script.setAttribute("data-reactions-enabled", "1");
    script.setAttribute("data-emit-metadata", "0");
    script.setAttribute("data-input-position", "bottom");
    script.setAttribute("data-theme", theme);
    script.setAttribute("data-lang", "zh-CN");
    script.setAttribute("crossorigin", "anonymous");
    script.setAttribute("data-giscus-injected", "1");
    script.async = true;

    container.appendChild(script);
    return true;
  }

  // ── 2. 向 giscus iframe 发送主题切换消息 ──────────────────────────────
  function sendGiscusTheme(theme) {
    const iframe = document.querySelector("iframe.giscus-frame");
    if (!iframe) return false;
    try {
      iframe.contentWindow.postMessage(
        { giscus: { setConfig: { theme: theme } } },
        "https://giscus.app"
      );
    } catch (e) {
      // iframe 跨域，部分浏览器可能抛异常，忽略即可
    }
    return true;
  }

  // ── 3. 监听 giscus iframe 创建，load 后同步主题（兜底）───────────────
  function observeGiscusFrame() {
    const wrapper = document.querySelector(".giscus");
    if (!wrapper) return;

    const observer = new MutationObserver(() => {
      const iframe = wrapper.querySelector("iframe.giscus-frame");
      if (!iframe) return;
      observer.disconnect();

      const applyTheme = () =>
        sendGiscusTheme(getSiteTheme() === "dark" ? "dark" : "light");

      if (iframe.contentDocument?.readyState === "complete") {
        applyTheme();
      } else {
        iframe.addEventListener("load", applyTheme, { once: true });
      }
    });
    observer.observe(wrapper, { childList: true, subtree: true });
  }

  // ── 4. 拦截 window.theme.setTheme，主题切换时同步 giscus ──────────────
  function patchThemeSetTheme() {
    if (!window.theme || window.__giscusPatchedSetTheme) return;
    window.__giscusPatchedSetTheme = true;

    const orig = window.theme.setTheme;
    window.theme.setTheme = function (val) {
      orig.call(this, val);
      sendGiscusTheme(val === "dark" ? "dark" : "light");
    };
  }

  // ── 5. 等待容器就绪后注入（含重试机制）────────────────────────────────
  function tryInject(retries) {
    if (injectGiscus()) {
      patchThemeSetTheme();
      observeGiscusFrame();
      return;
    }
    // 容器还不存在，等待下一帧再试
    if (retries > 0) {
      requestAnimationFrame(() => tryInject(retries - 1));
    }
  }

  // ── 6. 主初始化函数 ──────────────────────────────────────────────────
  function initGiscus() {
    window.__giscusPatchedSetTheme = false;
    tryInject(5); // 最多重试 5 帧（约 80ms），覆盖 View Transitions 延迟
  }

  // ── 首次加载 ─────────────────────────────────────────────────────────
  // 立即尝试注入；如果 DOM 还没就绪，DOMContentLoaded 兜底
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initGiscus, { once: true });
  } else {
    initGiscus();
  }

  // ── Astro View Transitions：页面切换后重新挂载 ────────────────────────
  document.addEventListener("astro:after-swap", () => {
    // after-swap 触发时新 DOM 已替换旧 DOM，但 Astro 可能还有微任务
    // 用 requestAnimationFrame 确保布局完成后再注入
    requestAnimationFrame(() => {
      initGiscus();
    });
  });
</script>
